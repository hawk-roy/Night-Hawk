# MySQL for local go run
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=go_order_service
MYSQL_USER=order_user
MYSQL_PASSWORD=order_pass
MYSQL_ROOT_PASSWORD=rootpass

# Redis for local go run
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Docker Compose app service uses service names:
# MYSQL_HOST=mysql
# REDIS_ADDR=redis:6379